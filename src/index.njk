---
layout: base
title: "My8OSS"
---

<section class="hero">
  <h1>Once a Myth, Now My8OSS</h1>
</section>

<section class="vision">
  <h2>We turn ideas into apps</h2>
  <div class="journey">
    <div class="node" data-label="Idea">
      <span class="dot"></span>
    </div>
    <div class="node" data-label="Build">
      <span class="dot"></span>
    </div>
    <div class="node" data-label="Apps">
      <span class="dot"></span>
    </div>
    <div class="journey-line">
      <div class="moving-dot"></div>
    </div>
  </div>
</section>

<section class="apps">
  <h2>All Apps</h2>
  <h3>This is where it begins.</h3>
  <div id="apps-grid">
    {% for app in collections.app %}
      <div class="card">
        {% if app.data.image %}
          <img src="{{ app.data.image }}" alt="{{ app.data.title }}">
        {% endif %}
        <h3>{{ app.data.title }}</h3>
        <p>{{ app.data.description }}</p>
        <a href="/apps/{{ app.fileSlug }}" class="open-btn">Open App →</a>
      </div>
    {% endfor %}
  </div>
</section>