{%- set link = app.data.link -%}
{%- set isAnchor = link and link | startsWith('#') -%}
{%- set isExternal = link and link | startsWith('http') -%}
{%- if isAnchor -%}
  {%- set anchorLabel = link | slice(1) | capitalize -%}
{%- endif -%}
{%- set docsUrl = "/docs/" + app.fileSlug -%}

<div class="app-banner">
  <div class="app-banner-left">
    {% if app.data.image %}
      <img
        src="{{ app.data.image }}"
        alt="{{ app.data.title }}"
        class="app-banner-logo"
        width="48"
        height="48"
      >
    {% endif %}
    <div class="app-banner-text">
      <h1 class="app-banner-title">{{ app.data.title }}</h1>
      <p class="app-banner-desc">{{ app.data.description }}</p>
    </div>
  </div>

  <div class="app-banner-right">
    {% if app.data.tags and app.data.tags.length > 0 %}
      <div class="app-banner-tags">
        {% for tag in app.data.tags %}<span class="tag">{{ tag }}</span>{% endfor %}
      </div>
    {% endif %}

    {% if app.data.version %}
      <span class="app-banner-version">Version: v{{ app.data.version }}</span>
    {% endif %}

    {% if app.data.license %}
      {% set lic = app.data.license | licenseLink %}
      {% if lic.url %}
        <a href="{{ lic.url }}" class="app-banner-license" target="_blank" rel="noopener noreferrer" title="View license details">License: {{ lic.short }}</a>
      {% else %}
        <span class="app-banner-license">License: {{ lic.short }}</span>
      {% endif %}
    {% endif %}

    <a href="{{ docsUrl }}" class="app-banner-btn">Docs</a>

    {% if link %}
      <a
        href="{{ link }}"
        class="app-banner-btn app-banner-btn-primary"
        {% if isExternal %}target="_blank" rel="noopener noreferrer"{% endif %}
      >
        {% if isAnchor %}Install ↓{% else %}Visit App ↗{% endif %}
      </a>
    {% endif %}

    {% if app.data.featured %}
      <span class="app-banner-featured">★ Featured</span>
    {% endif %}
  </div>
</div>