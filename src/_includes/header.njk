<header class="site-header" data-pagefind-ignore>
  <nav class="navbar">
    <!-- Logo – left -->
    <a href="/" class="logo">
      <img src="/images/logo.webp" alt="My8OSS – Home" width="100" height="33">
    </a>

    <button class="hamburger" id="hamburger-btn" aria-label="Open menu" aria-expanded="false">
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>
  </nav>
</header>

<div class="menu-overlay" id="menu-overlay" data-pagefind-ignore>
  <button class="menu-close" id="menu-close" aria-label="Close menu">&times;</button>
  <ul class="menu-links">
    <li><a href="/" class="menu-link">Home</a></li>
    <li><a href="/apps" class="menu-link">Apps</a></li>
    <li><a href="/docs" class="menu-link">Documentations</a></li>
    <li><a href="/about" class="menu-link">About My8OSS</a></li>
  </ul>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const hamburger = document.getElementById('hamburger-btn');
    const overlay = document.getElementById('menu-overlay');
    const closeBtn = document.getElementById('menu-close');

    // Open overlay
    hamburger?.addEventListener('click', () => {
      overlay?.classList.add('open');
      hamburger.classList.add('active');          // ← triggers cross animation
      hamburger.setAttribute('aria-expanded', 'true');
    });

    // Close overlay via close button
    closeBtn?.addEventListener('click', () => {
      overlay?.classList.remove('open');
      hamburger.classList.remove('active');       // ← resets to hamburger
      hamburger.setAttribute('aria-expanded', 'false');
    });

    // Close overlay when clicking a link
    overlay?.addEventListener('click', (e) => {
      if (e.target.tagName === 'A') {
        overlay.classList.remove('open');
        hamburger.classList.remove('active');
        hamburger.setAttribute('aria-expanded', 'false');
      }
    });
  });
</script>